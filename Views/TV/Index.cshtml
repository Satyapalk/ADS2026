@using System.Text.Json
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewBag.Screen as string ?? "all")</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            width: 100vw;
            height: 100vh;
            background: #000;
            overflow: hidden;
            font-family: sans-serif;
        }

        #img-display, #vid-display {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: none;
            position: absolute;
            inset: 0;
        }

        #waiting {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #333;
            gap: 0.5rem;
        }

            #waiting p {
                font-size: 1rem;
                letter-spacing: 0.05em;
            }

            #waiting span {
                font-size: 0.75rem;
                color: #555;
                font-family: monospace;
            }


    </style>
</head>
<body>

    <img id="img-display" src="" alt="TV Display" />
    <video id="vid-display" autoplay loop muted playsinline></video>

    <div id="waiting">
        <p>Waiting for content...</p>
        <span id="waiting-screen-name"></span>
    </div>

    <script>
        // JSON-escaped inline — no dependency on a page-level @{ } variable,
        // safe against quote-breakout / JS injection from the query string.
        const SCREEN = @Html.Raw(JsonSerializer.Serialize(ViewBag.Screen as string ?? "all"))
        const BASE_URL = 'https://localhost:7084'

        document.getElementById('waiting-screen-name').textContent = SCREEN

        const imgEl     = document.getElementById('img-display')
        const vidEl     = document.getElementById('vid-display')
        const waitingEl = document.getElementById('waiting')

        function mediaUrl(fileUrl) {
            return BASE_URL + (fileUrl.startsWith('/') ? '' : '/') + fileUrl
        }

        function showMedia(media) {
            const url = mediaUrl(media.fileUrl)
            if (media.fileType === 'video') {
                imgEl.style.display = 'none'
                vidEl.src = url
                vidEl.style.display = 'block'
                vidEl.load()
                vidEl.play()
            } else {
                vidEl.style.display = 'none'
                imgEl.src = url
                imgEl.style.display = 'block'
            }
            waitingEl.style.display = 'none'
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl(`${BASE_URL}/mediaHub`, { withCredentials: true })
            .withAutomaticReconnect()
            .build()

        // Expected payload shape from the server:
        // { fileName, fileType, fileUrl, screens: string[] | null, all: boolean }
            connection.on('ReceiveMedia', (media) => {
            console.log(`[${SCREEN}] Received: ${media.fileName}`)
            showMedia(media)
        })

        connection.start()
            .then(() => {
                return connection.invoke('JoinScreen', SCREEN)
            })
            .catch(err => console.error('SignalR error:', err))

        connection.onreconnected(() => {
            // Groups don't survive reconnects — must rejoin explicitly
            connection.invoke('JoinScreen', SCREEN).catch(err => console.error('Rejoin failed:', err))
        })
    </script>
</body>
</html>